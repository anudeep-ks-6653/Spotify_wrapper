{
  "name": "spotify-wrapper-frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "express": "^4.18.2",
    "serve-static": "^1.15.0"
  },
  "devDependencies": {
    "live-server": "^1.2.2"
  },
  "scripts": {
    "start": "live-server --port=3000 --host=127.0.0.1 --entry-file=index.html",
    "dev": "live-server --port=3000 --host=127.0.0.1 --entry-file=index.html --watch=.",
    "build": "echo 'Build complete - static files ready'",
    "serve": "node server.js"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
